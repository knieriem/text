Calculate the first 18 fibonacci numbers recursively

-- input --

fn fib {
	if ~ $1 0 1 {
		echo $1
		return
	}
	expr `{fib `{expr $1 - 1}} + `{fib `{expr $1 - 2}}
}

for i in ...18 {
	echo $i: `{fib $i}
}

-- stdout --
0: 0
1: 1
2: 1
3: 2
4: 3
5: 5
6: 8
7: 13
8: 21
9: 34
10: 55
11: 89
12: 144
13: 233
14: 377
15: 610
16: 987
17: 1597

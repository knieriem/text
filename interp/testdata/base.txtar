Basic tests

-- input --
echo foo

fn f {
	echo	f: $1

	if ~ $#* 1 {
		echo f: $1^bar
		return
	}
	echo f: $#* | $*
	echo 'f[2]': $2
}

f foo
f 1 2 3 4

fn h echo hello

h

printf 'fmt %02x %.2f %q %s\n' 10 1.666 abc "def"
printf "a\tb\nc%d\n" 1

expr 5 * 200ms
expr 200ms * 4
expr 2 * 5.2
expr -4 + 3
expr -4.1 + 3
expr -4.1 + 3.2
expr 4 - 2
expr 500ms / 2
expr 5 / 2
expr 5 / 2.5
expr 5.5 / 2

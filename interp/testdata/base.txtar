Basic tests

-- input --
echo foo

fn f {
	echo	f: $1

	if ~ $#* 1 {
		echo f: $1^bar
		return
	}
	echo f: $#* | $*
	echo 'f[2]': $2
}

f foo
f 1 2 3 4

fn h echo hello

h

printf 'fmt %02x %.2f %q %s\n' 10 1.666 abc "def"
printf "a\tb\nc%d\n" 1

-- stdout --
foo
f: foo
f: foobar
f: 1
f: 4 | 1 2 3 4
f[2]: 2
hello
fmt 0a 1.67 "abc" def
a	b
c1
-- stderr --
